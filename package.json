{
  "name": "honobackend",
  "version": "1.0.0",
  "description": "Hono/TypeScript backend API with PostgreSQL and Drizzle ORM",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "bun --hot index.ts",
    "db:generate": "drizzle-kit generate",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "start": "bun run index.ts",
    "build": "tsc --noEmit && bun build index.ts --minify --outdir dist --target bun",
    "build:compile": "tsc --noEmit && bun build index.ts --minify --outfile bin/honobackend --compile --target bun",
    "start:prod": "bun run dist/index.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "clean": "rm -rf dist bin",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "hono-rate-limiter": "^0.5.3",
    "postgres": "^3.4.9",
    "resend": "^6.10.0",
    "sanitize-html": "^2.17.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.11",
    "@types/sanitize-html": "^2.16.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "keywords": [
    "hono",
    "typescript",
    "backend",
    "api",
    "postgresql",
    "drizzle-orm",
    "bun"
  ],
  "author": "pilput",
  "license": "MIT"
}
